PORT=5000
# Local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/smart-campus-issues
# MongoDB Atlas (replace with YOUR cluster host from Atlas → Connect → Drivers):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart-campus-issues?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/smart-campus-issues
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
ALLOW_ADMIN_REGISTRATION=true
